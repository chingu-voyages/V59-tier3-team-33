# Frontend Configuration
FRONTEND_URL=http://localhost:3000
FRONTEND_EMAIL_VERIFICATION_PATH_NAME=verify-email
FRONTEND_PASSWORD_RESET_PATH_NAME=reset-password
FRONTEND_SHARE_PATH_NAME=share-trip

# Email Configuration (Mailtrap for development)
# Get credentials from https://mailtrap.io/
EMAIL_HOST_USER=your_mailtrap_username
EMAIL_HOST_PASSWORD=your_mailtrap_password
EMAIL_PORT=2525
DEFAULT_FROM_EMAIL=joyroute.support@gmail.com

# Geoapify API (for route optimization)
# Get free API key from https://www.geoapify.com/
# Free tier: 3,000 requests/day
GEOAPIFY_API_KEY=your_geoapify_api_key

# LLM Configuration (for AI date suggestions)
# Get free API key from https://console.groq.com/
LLM_PROVIDER=groq
LLM_PROVIDER_API_KEY=your_groq_api_key
LLM_MODEL=llama3-8b-8192

# Optional: JWT Token Lifetimes (defaults shown)
# ACCESS_TOKEN_LIFETIME=3  # days
# REFRESH_TOKEN_LIFETIME=7  # days
